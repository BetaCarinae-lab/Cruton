CRUTON {
    Program = Section+
    Statement = Out
              | Ini 
              | Mov

    Section = MAIN

    number = digit+

    Out = "out" expr

    expr = string
         | number
         | ident

    string = "\"" (~"\"" any)* "\""

    End = "end"

    MAIN = ".entry" ":" (~End Statement)* End

    Ini = "ini" ident

    Mov = "mov" ident "," expr

    ident = letter idchar*

    idchar = letter | "_" | digit
}