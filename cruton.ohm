CRUTON {
    Program = Section+
    Statement = Out

    Section = RES | DAT | MAIN

    Out = "out" Expr

    Expr = string

    string = "\"" (~"\"" any)* "\""

    End = "end"

    RES = ".res" ":" (~End Statement)* End

    DAT = ".dat" ":" (~End Statement)* End

    MAIN = ".entry" ":" (~End Statement)* End

    ident = letter idchar*

    idchar = letter | "_" | digit
}